---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Toc from "@/components/Toc.astro";
import TagPill from "@/components/TagPill.astro";
import { formatDate } from "@/data/format";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description} lang="zh-CN">
  <div class="container-page grid gap-6 py-9 xl:grid-cols-[minmax(0,1fr)_260px]">
    <article class="apple-card min-w-0">
      <header>
        <p class="text-sm text-[color:var(--muted)]">
          <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
          {
            post.data.updatedDate && (
              <span> · 更新于 {formatDate(post.data.updatedDate)}</span>
            )
          }
        </p>
        <h1 class="mt-2 text-[28px] font-extrabold leading-tight tracking-[-0.03em] text-[color:var(--text)] md:text-[34px]">
          {post.data.title}
        </h1>
        {
          post.data.tags.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-1.5">
              {post.data.tags.map((tag) => (
                <TagPill label={tag} />
              ))}
            </div>
          )
        }
      </header>
      <div class="article-prose mt-8">
        <Content />
      </div>
      <footer class="mt-10 border-t border-[color:var(--border)] pt-5">
        <a class="pill-link" href="/blog/">← 返回博客列表</a>
      </footer>
    </article>
    <Toc headings={headings} />
  </div>
</BaseLayout>
