---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="404" description="Page not found.">
  <div class="container-page flex justify-center py-24">
    <section class="apple-card max-w-[520px] text-center">
      <p class="text-[42px] font-extrabold tracking-tight text-[color:var(--text)]">404</p>
      <h1 class="mt-2 text-xl font-bold text-[color:var(--text)]">Page not found</h1>
      <p class="mt-3 text-[15px] text-[color:var(--muted)]">
        The page you are looking for doesn't exist or has been moved.
      </p>
      <div class="mt-6 flex justify-center">
        <a class="pill-link" href="/">← Back to Home</a>
      </div>
    </section>
  </div>
</BaseLayout>
