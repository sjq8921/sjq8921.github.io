---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig, education, awards, news } from "@/data/site";
---

<BaseLayout>
  <div class="container-page grid gap-[18px] py-9">
    <section class="apple-card grid items-center gap-6 md:grid-cols-[1fr_auto] md:gap-[42px]">
      <div>
        <h1 class="mb-2 text-[34px] font-extrabold leading-[1.12] tracking-[-0.045em] text-[color:var(--text)] md:text-[42px]">
          {siteConfig.name}
        </h1>
        <p class="mb-2.5 text-[15.5px] text-[color:var(--body)] md:text-[17px]">
          undergraduate student<br />Shandong University of Finance and Economics
        </p>
        <p class="mt-3 max-w-[760px] text-[15.5px] leading-[1.62] text-[color:var(--text)] md:text-base">
          I am an undergraduate student from the Department of Computer Science and Artificial
          Intelligence, Shandong University of Finance and Economics. My research focuses on
          computer vision.
        </p>
        <div class="mt-[18px] flex flex-wrap gap-2.5">
          <a class="pill-link" href={`mailto:${siteConfig.email}`}>Email</a>
          <a class="pill-link" href={siteConfig.github} target="_blank" rel="noopener">GitHub</a>
          <a class="pill-link" href={siteConfig.scholar} target="_blank" rel="noopener">Google Scholar</a>
        </div>
      </div>
      <div class="justify-self-center overflow-hidden rounded-3xl border border-[color:var(--border)] bg-white shadow-soft md:justify-self-end">
        <img src="/assets/profile.jpg" alt="Profile photo" class="block h-[155px] w-auto md:h-[180px]" />
      </div>
    </section>

    <section class="apple-card" id="experience">
      <h2 class="section-title mb-3.5">Experience</h2>
      <div class="grid gap-3.5 md:grid-cols-[1.35fr_1fr]">
        <div class="panel">
          <h3 class="mb-2.5 text-[17px] font-bold text-[color:var(--text)]">Education &amp; Experience</h3>
          {
            education.map((item) => (
              <div class="mb-3 border-b border-[color:var(--border)] pb-2.5 last:mb-0 last:border-b-0 last:pb-0">
                <div class="text-sm text-[color:var(--muted)]">{item.time}</div>
                <div class="text-[color:var(--text)]">
                  {item.link ? (
                    <a href={item.link} target="_blank" rel="noopener" class="text-[color:var(--primary)] hover:underline">
                      {item.title}
                    </a>
                  ) : (
                    item.title
                  )}
                </div>
              </div>
            ))
          }
        </div>
        <div class="panel">
          <h3 class="mb-2.5 text-[17px] font-bold text-[color:var(--text)]">Selected Awards</h3>
          <div class="flex flex-wrap gap-1.5">
            {awards.map((award) => <span class="chip">{award}</span>)}
          </div>
        </div>
      </div>
    </section>

    <section class="apple-card" id="news">
      <h2 class="section-title mb-3.5">News</h2>
      {
        news.length > 0 ? (
          <ul class="grid list-disc gap-2 pl-[18px] text-[color:var(--body)]">
            {news.map((item) => (
              <li>
                {item.date && <span class="text-[color:var(--muted)]">[{item.date}] </span>}
                {item.link ? (
                  <a href={item.link} class="text-[color:var(--primary)] hover:underline">
                    {item.text}
                  </a>
                ) : (
                  item.text
                )}
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-[color:var(--muted)]">No news yet.</p>
        )
      }
    </section>
  </div>
</BaseLayout>
