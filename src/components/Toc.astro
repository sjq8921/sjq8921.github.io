---
type Heading = {
  depth: number;
  slug: string;
  text: string;
};

type Props = {
  headings: Heading[];
};

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth <= 3);
---

{
  items.length >= 2 && (
    <aside class="sticky top-24 hidden self-start xl:block">
      <div class="panel rounded-[20px] p-5">
        <h2 class="text-sm font-bold text-[color:var(--text)]">目录</h2>
        <nav class="mt-4 grid gap-2 text-sm" aria-label="Table of contents">
          {items.map((item) => (
            <a
              class:list={[
                "rounded-xl px-2 py-1.5 text-[color:var(--muted)] hover:bg-[color:var(--chip-bg)] hover:text-[color:var(--primary)]",
                item.depth === 3 && "pl-6"
              ]}
              href={`#${item.slug}`}
            >
              {item.text}
            </a>
          ))}
        </nav>
      </div>
    </aside>
  )
}
