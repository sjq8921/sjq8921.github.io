---
import { navItems, siteConfig } from "@/data/site";
import Icon from "./Icon.astro";
import ThemeToggle from "./ThemeToggle.astro";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="sticky top-0 z-50 border-b border-[color:var(--border)] bg-[color:var(--bg)]/80 backdrop-blur-xl">
  <div class="container-page flex h-16 items-center justify-between gap-6">
    <a href="/" class="flex min-w-0 items-center gap-2 rounded-full font-bold tracking-tight text-[color:var(--text)]" aria-label="Home">
      <span translate="no">{siteConfig.name}</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Main navigation">
      {
        navItems.map((item) => {
          const isActive = item.href === "/" ? currentPath === "/" : currentPath.startsWith(item.href);
          return (
            <a
              href={item.href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "rounded-full px-3 py-2 text-sm font-semibold transition-colors hover:bg-[color:var(--chip-bg)] hover:text-[color:var(--text)]",
                isActive ? "text-[color:var(--primary)]" : "text-[color:var(--muted)]"
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-1">
      <ThemeToggle />
      <a
        href={siteConfig.github}
        class="hidden h-10 w-10 items-center justify-center rounded-full text-[color:var(--body)] transition-colors hover:bg-[color:var(--chip-bg)] hover:text-[color:var(--text)] sm:inline-flex"
        aria-label="Open GitHub"
      >
        <Icon name="github" />
      </a>
      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full text-[color:var(--body)] transition-colors hover:bg-[color:var(--chip-bg)] hover:text-[color:var(--text)] md:hidden"
        aria-label="Open navigation menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
        data-menu-toggle
      >
        <Icon name="menu" />
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="container-page hidden border-t border-[color:var(--border)] py-3 md:hidden" aria-label="Mobile navigation" data-mobile-menu>
    <div class="grid gap-1">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="rounded-2xl px-3 py-3 text-sm font-semibold text-[color:var(--body)] transition-colors hover:bg-[color:var(--chip-bg)] hover:text-[color:var(--text)]"
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script is:inline>
  (() => {
    const button = document.querySelector("[data-menu-toggle]");
    const menu = document.querySelector("[data-mobile-menu]");
    if (!button || !menu) return;
    button.addEventListener("click", () => {
      const expanded = button.getAttribute("aria-expanded") === "true";
      button.setAttribute("aria-expanded", String(!expanded));
      menu.classList.toggle("hidden", expanded);
    });
  })();
</script>
