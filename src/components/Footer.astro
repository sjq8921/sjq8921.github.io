---
import { siteConfig } from "@/data/site";
import Icon from "./Icon.astro";
---

<footer class="mt-24 border-t border-[color:var(--border)]">
  <div class="container-page flex flex-col items-center gap-4 py-10">
    <div class="flex gap-2">
      <a class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[color:var(--border)] bg-[color:var(--surface)] text-[color:var(--body)] hover:text-[color:var(--primary)]" href={siteConfig.github} aria-label="GitHub">
        <Icon name="github" />
      </a>
      <a class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[color:var(--border)] bg-[color:var(--surface)] text-[color:var(--body)] hover:text-[color:var(--primary)]" href={`mailto:${siteConfig.email}`} aria-label="Email">
        <Icon name="mail" />
      </a>
    </div>
    <p class="text-center text-[13.5px] text-[color:var(--muted)]">
      © 2026 {siteConfig.name}. Built with Astro &amp; GitHub Pages.
    </p>
  </div>
</footer>
